@model GestaoEventos.Models.Categoria

@{
    ViewData["Title"] = "Detalhes da Categoria";
}

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5">
        <div class="card shadow border-0 p-4">
            <h4 class="text-secondary mb-3">
                <i class="fa-solid fa-file-lines me-2"></i>Detalhes da Categoria
            </h4>

            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted small text-uppercase fw-semibold">
                    @Html.DisplayNameFor(model => model.Nome)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Nome)
                </dd>
            </dl>

            <hr />

            <div class="d-grid gap-2">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-secondary py-2 shadow-sm text-white fw-bold">
                    <i class="fa-solid fa-pen-to-square me-1"></i> Editar
                </a>
                <a asp-action="Index" class="btn btn-link text-muted">Voltar para a Lista</a>
            </div>
        </div>
    </div>
</div>
